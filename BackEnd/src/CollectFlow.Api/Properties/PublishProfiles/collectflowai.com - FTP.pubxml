<Project>
  <PropertyGroup>
    <WebPublishMethod>FTP</WebPublishMethod>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <SiteUrlToLaunchAfterPublish>http://www.collectflowai.com/myapp</SiteUrlToLaunchAfterPublish>
    <LaunchSiteAfterPublish>true</LaunchSiteAfterPublish>
    <ExcludeApp_Data>false</ExcludeApp_Data>
    <ProjectGuid>0e570255-b293-41df-bd4f-a1b68c0420a1</ProjectGuid>
    <publishUrl>ftp://w26.winhost.com:21</publishUrl>
    <DeleteExistingFiles>false</DeleteExistingFiles>
    <FtpPassiveMode>true</FtpPassiveMode>
    <FtpSitePath>myapp</FtpSitePath>
    <UserName>teleatla</UserName>
    <_SavePWD>false</_SavePWD>
  </PropertyGroup>
</Project>